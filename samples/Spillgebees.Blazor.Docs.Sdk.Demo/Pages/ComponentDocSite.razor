@page "/components/doc-site"

<Breadcrumb Section="components" PageName="DocSite"
            ApiReferenceUrl="api/Spillgebees.Blazor.Docs.Sdk.Components.DocSite"
            SourceUrl="https://github.com/Spillgebees/Blazor.Docs.Sdk/blob/main/src/Spillgebees.Blazor.Docs.Sdk/Components/DocSite.razor" />
<OnThisPage />

<h1>DocSite</h1>
<p>Root layout component that wraps the entire docs site with a top bar, sidebar, content area, and footer.</p>

<h2 id="basic_usage">// basic_usage</h2>
<p>Replace the contents of <code>MainLayout.razor</code> with a <code>DocSite</code> wrapper, passing your navigation structure and project metadata.</p>

<CodeBlock Files="@_basicUsage" Language="razor" />

<h2 id="navigation_structure">// navigation_structure</h2>
<p>Navigation is defined as an array of <code>NavSection</code> records, each containing a list of <code>NavPage</code> entries. Sections appear as labeled groups in the sidebar.</p>

<CodeBlock Files="@_navStructure" Language="csharp" />

@code {
    private static readonly Dictionary<string, string> _basicUsage = new()
    {
        ["MainLayout.razor"] = """
            @inherits LayoutComponentBase

            <DocSite ProjectName="My Project"
                     LogoEmoji="🚀"
                     GitHubUrl="https://github.com/my-org/my-project"
                     Navigation="@Navigation">
                @Body
            </DocSite>

            @code {
                private static readonly NavSection[] Navigation =
                [
                    new("Getting Started", [
                        new NavPage("Home", "/"),
                        new NavPage("Installation", "/installation"),
                    ]),
                    new("Components", [
                        new NavPage("MyComponent", "/components/my-component"),
                    ]),
                ];
            }
            """,
    };

    private static readonly Dictionary<string, string> _navStructure = new()
    {
        ["Navigation.cs"] = """
            // NavSection groups pages under a collapsible heading
            new NavSection("Getting Started", [
                new NavPage("Home", "/"),
                new NavPage("Installation", "/installation"),
            ]),

            // NavPage maps a display title to a route
            new NavPage("MyComponent", "/components/my-component")
            """,
    };
}
