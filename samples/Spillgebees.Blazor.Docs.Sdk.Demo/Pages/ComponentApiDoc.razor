@page "/components/api-doc"

<Breadcrumb Section="components" PageName="ApiDoc"
            ApiReferenceUrl="/api/Spillgebees.Blazor.Docs.Sdk.Components.ApiDoc"
            SourceUrl="https://github.com/Spillgebees/Blazor.Docs.Sdk/blob/main/src/Spillgebees.Blazor.Docs.Sdk/Components/ApiDoc.razor" />
<OnThisPage />

<h1>ApiDoc</h1>
<p>Renders auto-generated API documentation for a type, showing properties, methods, events, and enum values.</p>

<h2 id="resolve_by_type">// resolve_by_type</h2>
<p>Pass a <code>System.Type</code> to look up the generated API manifest embedded in the assembly at build time.</p>

<CodeBlock Files="@_byType" Language="razor" />

<h2 id="resolve_by_type_info">// resolve_by_type_info</h2>
<p>Supply a pre-loaded <code>ApiTypeInfo</code> directly when you have already fetched or constructed the metadata.</p>

<CodeBlock Files="@_byTypeInfo" Language="razor" />

<h2 id="api_reference_page_pattern">// api_reference_page_pattern</h2>
<p>The typical pattern is a routed page that maps a URL segment to a type and renders <code>ApiDoc</code> conditionally.</p>

<CodeBlock Files="@_apiPage" Language="razor" />

@code {
    private static readonly Dictionary<string, string> _byType = new()
    {
        ["ApiReference.razor"] = """
            <ApiDoc Type="typeof(MyComponent)" />
            """,
    };

    private static readonly Dictionary<string, string> _byTypeInfo = new()
    {
        ["ApiReference.razor"] = """
            @* Or supply a pre-loaded ApiTypeInfo directly *@
            <ApiDoc TypeInfo="@_typeInfo" />

            @code {
                private ApiTypeInfo? _typeInfo;
            }
            """,
    };

    private static readonly Dictionary<string, string> _apiPage = new()
    {
        ["ApiReferencePage.razor"] = """
            @page "/api/{TypeFullName}"

            @if (_typeInfo is not null)
            {
                <ApiDoc TypeInfo="@_typeInfo" />
            }
            else
            {
                <h1>Type not found</h1>
                <p>No API documentation available for <code>@TypeFullName</code>.</p>
            }

            @code {
                [Parameter]
                public string TypeFullName { get; set; } = "";

                private ApiTypeInfo? _typeInfo;

                private static readonly Dictionary<string, ApiTypeInfo> _types = BuildTypeMap();

                protected override void OnParametersSet() =>
                    _types.TryGetValue(TypeFullName, out _typeInfo);
            }
            """,
    };
}
