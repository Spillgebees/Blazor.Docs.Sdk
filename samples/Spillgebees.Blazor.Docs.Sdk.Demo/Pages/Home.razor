@page "/"

<div class="doc-hero">
    <div class="doc-hero-brand">Spillgebees</div>
    <h1 class="doc-hero-title">Blazor.Docs.Sdk</h1>
    <p class="doc-hero-tagline">
        Everything you need to build and deploy documentation sites
        for your Blazor component libraries.
    </p>
    <div class="doc-hero-actions">
        <a href="/installation" class="doc-hero-cta-primary">Get Started</a>
        <a href="https://github.com/Spillgebees/Blazor.Docs.Sdk"
           target="_blank" rel="noopener noreferrer"
           class="doc-hero-cta-secondary">View on GitHub</a>
    </div>
</div>

<div class="doc-cards">
    <div class="doc-card">
        <div class="doc-card-icon">📐</div>
        <h3 class="doc-card-title">Shell Layout</h3>
        <p class="doc-card-desc">Sidebar, top bar, theme toggle, footer. One component wraps your entire docs site.</p>
    </div>
    <div class="doc-card">
        <div class="doc-card-icon">👁</div>
        <h3 class="doc-card-title">Live Examples</h3>
        <p class="doc-card-desc">Show components running alongside their auto-extracted, syntax-highlighted source code.</p>
    </div>
    <div class="doc-card">
        <div class="doc-card-icon">📖</div>
        <h3 class="doc-card-title">API Reference</h3>
        <p class="doc-card-desc">Auto-generated from XML doc comments and reflection. Parameters, methods, events.</p>
    </div>
</div>
