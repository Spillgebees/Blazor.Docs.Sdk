@using Microsoft.AspNetCore.Components
@typeparam TComponent where TComponent : IComponent

<div class="example-view">
    <div class="example-view-toggle">
        <button class="example-view-mode @(_mode == "preview" ? "active" : "")"
                @onclick="@(() => _mode = "preview")">preview</button>
        <button class="example-view-mode @(_mode == "code" ? "active" : "")"
                @onclick="@(() => _mode = "code")">code</button>
    </div>

    @if (_mode == "preview")
    {
        <div class="example-view-preview">
            @ChildContent
        </div>
    }
    else if (_sourceFiles.Count > 0)
    {
        <CodeBlock Files="@_sourceFiles" Language="razor" />
    }
    else
    {
        <div class="example-view-no-source">
            source not available
        </div>
    }
</div>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public Type[]? AdditionalSources { get; set; }

    private readonly Dictionary<string, string> _sourceFiles = [];
    private string _mode = "preview";

    protected override void OnInitialized()
    {
        LoadSourceFiles(typeof(TComponent));

        if (AdditionalSources is not null)
        {
            foreach (var type in AdditionalSources)
            {
                LoadSourceFiles(type);
            }
        }
    }

    private void LoadSourceFiles(Type type)
    {
        var assembly = type.Assembly;
        var resourcePrefix = $"SourceEmbed:{type.FullName}";

        foreach (var resourceName in assembly.GetManifestResourceNames())
        {
            if (!resourceName.StartsWith(resourcePrefix, StringComparison.Ordinal))
            {
                continue;
            }

            using var stream = assembly.GetManifestResourceStream(resourceName);
            if (stream is null)
            {
                continue;
            }

            using var reader = new StreamReader(stream);
            var fileName = resourceName[(resourcePrefix.Length + 1)..];
            _sourceFiles[fileName] = reader.ReadToEnd();
        }
    }
}
