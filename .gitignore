## ==========================================================================
## Universal .gitignore -- covers .NET, TypeScript/Node, and IDE/OS artifacts
## ==========================================================================

## ---- .NET build outputs ----
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Ll]og/
[Ll]ogs/

## ---- .NET tooling ----
*.user
*.suo
*.userossscache
*.sln.docstates
*.DotSettings.user
project.lock.json
project.fragment.lock.json
artifacts/

## ---- NuGet ----
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
!**/[Pp]ackages/*.props
!**/[Pp]ackages/*.targets
*.nuget.props
*.nuget.targets
.nuget/

## ---- Test results & coverage ----
TestResults/
[Cc]overage*/
*.trx
*.coverage
*.coveragexml
*.opencover.xml
lcov.info

## ---- Node / TypeScript ----
node_modules/
dist/
build/
*.tsbuildinfo
.turbo/
.cache/
.parcel-cache/

## ---- Environment ----
.env
.env.*
!.env.example

## ---- IDE: Visual Studio ----
.vs/
*.rsuser
*.ncb
*.aps
*.cachefile
*.psess
*.vsp
*.vspx
*.sap
*.e2e
$tf/
*.gpState
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings

## ---- IDE: JetBrains (Rider, IntelliJ) ----
.idea/
*.iml

## ---- IDE: VS Code ----
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

## ---- OS: macOS ----
.DS_Store
._*
.Spotlight-V100
.Trashes

## ---- OS: Windows ----
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

## ---- OS: Linux ----
*~
.fuse_hidden*
.Trash-*
.nfs*

## ---- OpenCode ----
.opencode/

## ---- Claude ----
.claude/

## ---- Superpowers ----
.superpowers/

## ---- Vite build output ----
src/Spillgebees.Blazor.Docs.Sdk/wwwroot/*.lib.module.js
src/Spillgebees.Blazor.Docs.Sdk/wwwroot/*.lib.module.js.map

## ---- Docs SDK build output ----
**/DocsSdk/

## ---- Misc ----
*.log
*.tmp
*.temp
*.bak
*.swp
*.swo
